# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=4096

# Redis
REDIS_URL=redis://localhost:6379

# Postgres
DATABASE_URL=postgresql+asyncpg://sumula:sumula@localhost:5432/sumula

# Upload limits
MAX_UPLOAD_MB=20
MAX_FILES=10

# Working directory for job files
WORKDIR_PATH=/tmp/sumula_workdir

# Web of Science Starter API (optional)
WOS_API_KEY=

# Email (MailerSend SMTP)
SMTP_HOST=smtp.mailersend.net
SMTP_PORT=587
SMTP_USERNAME=MS_xxxx@yourdomain.mlsender.net
SMTP_PASSWORD=mssp....
MAIL_DEFAULT_SENDER=sumula@yourdomain.com
MAIL_DEFAULT_SENDER_NAME=Súmula FAPESP
